---
import Layout from '../components/Layout.astro';
---
<Layout title="Página não encontrada" description="A página requisitada não foi encontrada.">
  <div class="container page">
    <header class="hero" aria-hidden="false">
      <div class="hero-inner">
        <div class="hero-brand">
          <h1>Página não encontrada</h1>
          <p class="text-muted hero-tagline">A página requisitada não foi encontrada.</p>
        </div>
      </div>
    </header>

    <main class="card content">
      <p class="lead">
        Desculpe, não conseguimos encontrar o que você procura.
      </p>

      <p>
        Tente navegar usando o menu acima ou retorne à <a href="/">página inicial</a>.
      </p>
    </main>
  </div>
</Layout>
