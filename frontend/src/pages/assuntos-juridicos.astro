---
import Layout from '../components/Layout.astro';
---
<Layout title="Assuntos Jurídicos" description="Informações sobre atuação jurídica e documentos relacionados.">
  <div class="container page">
    <header class="hero" aria-hidden="false">
      <div class="hero-inner">
        <div class="hero-brand">
          <h1>Assuntos Jurídicos</h1>
          <p class="text-muted hero-tagline">Informações sobre atuação jurídica e documentos relacionados.</p>
        </div>
      </div>
    </header>

    <main class="card content">
      <h1>Assuntos Jurídicos</h1>
      <p class="lead">Posts e materiais sobre atuação jurídica da AGAFIM.</p>
      
      {posts.length === 0 ? (
        <p>Carregando ou sem posts jurídicos disponíveis ainda.</p>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <article class="post-card p-6 border rounded-lg hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-bold mb-2"><a href={`/posts/${post.slug}`}>{post.title}</a></h3>
              <p class="text-muted mb-4">{post.summary}</p>
              <p class="text-sm text-blue-400 mb-2">Categoria: Jurídico | {new Date(post.publishedAt).toLocaleDateString()}</p>
              <a href={`/posts/${post.slug}`} class="inline-block px-4 py-2 bg-blue-600 rounded hover:bg-blue-700 transition">Ler mais</a>
            </article>
          ))}
        </div>
      )}
    </main>

    <script>
      let posts = [];
      async function loadPosts() {
        posts = await (await import('../lib/api.js')).fetchPostsByCategory('jurídico');
        // Trigger Astro re-render if needed, but since client list
        // For simplicity, use replaceChildren or full reload, but demo with window.posts = posts;
        console.log('Posts jurídicos:', posts); // Replace with dynamic render
      }
      loadPosts();
      window.postsJur = posts; // Global for debug
    </script>
  </div>
</Layout>
