---
import Layout from '../components/Layout.astro';
import { fetchPostsByCategory } from '../lib/api';
export const prerender = true;

const posts = await fetchPostsByCategory('parlamentar');
---
<Layout title="Assuntos Parlamentares" description="Ações e posicionamentos da AGAFIM sobre temas parlamentares.">
  <div class="container page">
    <header class="hero" aria-hidden="false">
      <div class="hero-inner">
        <div class="hero-brand">
          <h1>Assuntos Parlamentares</h1>
          <p class="text-muted hero-tagline">Ações e posicionamentos da AGAFIM sobre temas parlamentares.</p>
        </div>
      </div>
    </header>

    <main class="card content">
      <h1>Assuntos Parlamentares</h1>
      <p class="lead">Posts sobre temas parlamentares e legislativos da AGAFIM.</p>
      {posts.length === 0 ? (
      
        <p>Carregando ou sem posts parlamentares disponíveis ainda.</p>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <article class="post-card p-6 border rounded-lg hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-bold mb-2"><a href={`/posts/${post.slug}`}>{post.title}</a></h3>
              <p class="text-muted mb-4">{post.summary}</p>
              <p class="text-sm text-blue-400 mb-2">Categoria: Parlamentar | {new Date(post.publishedAt).toLocaleDateString()}</p>
              <a href={`/posts/${post.slug}`} class="inline-block px-4 py-2 bg-blue-600 rounded hover:bg-blue-700 transition">Ler mais</a>
            </article>
          ))}
        </div>
      )}
    </main>

    <script>
      // Optional client-side refresh
      async function refreshPosts() {
        const { fetchPostsByCategory } = await import('../lib/api');
        const newPosts = await fetchPostsByCategory('parlamentar');
        console.log('Refreshed posts parlamentares:', newPosts);
      }
      if (typeof window !== 'undefined') {
        (window as any).refreshPostsPar = refreshPosts;
      }
    </script>
  </div>
</Layout>
