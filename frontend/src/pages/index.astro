---
import Layout from '../components/Layout.astro';
---
<Layout title="Home" description="Site oficial da AGAFIM - Associação Gaúcha dos Auditores e Fiscais Tributários Municipais">
  <div class="container page">
    <header class="hero" aria-hidden="false">
      <div class="hero-inner">
        <div class="hero-brand">
          <h1>Bem-vindo à AGAFIM</h1>
          <p class="text-muted hero-tagline">Associação Gaúcha dos Auditores e Fiscais Tributários Municipais</p>
        </div>
      </div>
    </header>

    <main class="card content">
      <p class="lead">
        Representamos a categoria no Rio Grande do Sul. Notícias, publicações, informações e canais de contato.
      </p>

      <div class="roles-grid">
        <a class="role-card" href="/noticias" style="text-decoration: none;">
          Notícias
        </a>
        <a class="role-card" href="/estatuto" style="text-decoration: none;">
          Estatuto
        </a>
        <a class="role-card" href="/denuncias" style="text-decoration: none;">
          Denúncias
        </a>
        <a class="role-card" href="/area-do-usuario" style="text-decoration: none;">
          Área do Usuário
        </a>
      </div>
    </main>
  </div>
</Layout>
