---
import Layout from '../components/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Home" description="Site oficial da AGAFIM - Associação Gaúcha dos Auditores e Fiscais Tributários Municipais">
  <div class="container page">
    <header class="hero" aria-hidden="false">
      <div class="hero-inner">
        <div class="hero-brand">
          <h1>Bem-vindo à AGAFIM</h1>
        </div>
      </div>
    </header>

    <main class="card content">
      <p class="lead">
        Representamos a categoria no Rio Grande do Sul. Notícias, publicações, informações e canais de contato.
      </p>

      <div class="roles-grid">
        <a class="role-card" href={`${base}noticias`} style="text-decoration: none;">
          Notícias
        </a>
        <a class="role-card" href={`${base}estatuto`} style="text-decoration: none;">
          Estatuto
        </a>
        <a class="role-card" href={`${base}denuncias`} style="text-decoration: none;">
          Denúncias
        </a>
        <a class="role-card" href={`${base}area-do-usuario`} style="text-decoration: none;">
          Área do Usuário
        </a>
      </div>
    </main>
  </div>
</Layout>
