---
import Layout from '../../components/Layout.astro'
import { fetchPostBySlug, fetchPosts, type Post } from '../../lib/api'

export async function getStaticPaths() {
  const posts = await fetchPosts();
  return posts.map(post => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params

// Fetch post dynamically
const post: Post | null = await fetchPostBySlug(slug as string)

if (!post) {
  return Astro.redirect('/404')
}
---

<Layout title={post.title}>
  <article class="post">
    <h1>{post.title}</h1>
    <p class="summary">{post.summary}</p>
    <div class="content" set:html={post.content} />
    <p class="author">Por: {post.author?.email || 'Anônimo'}</p>
    <p class="date">Publicado em: {new Date(post.createdAt).toLocaleDateString('pt-BR')}</p>
  </article>
</Layout>

<style>
  .post {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }
  .summary {
    font-style: italic;
    margin-bottom: 1rem;
  }
  .content {
    margin-bottom: 2rem;
  }
  .author, .date {
    font-size: 0.9rem;
    color: #666;
  }
</style>