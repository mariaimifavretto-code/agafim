---
import Layout from '../components/Layout.astro';
---
<Layout title="Área do Usuário" description="Área restrita para associados com acesso a conteúdos exclusivos.">
  <div class="container page">
    <header class="hero" aria-hidden="false">
      <div class="hero-inner">
        <div class="hero-brand">
          <p class="text-muted hero-tagline">Acesso reservado para associados.</p>
        </div>
      </div>
    </header>

    <main class="card content" id="admin-main">
      <!-- Login Form -->
      <div id="login-section">
        <p class="lead">Área do Admin - Login</p>
        <form id="login-form" style="margin-top: 1.5rem;">
          <label style="display: block; margin: 0.75rem 0 0.35rem;">E-mail</label>
          <input id="email" type="email" placeholder="admin@agafim.org.br" required style="width: 100%; padding: 0.7rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.28); color: var(--text);" />

          <label style="display: block; margin: 0.75rem 0 0.35rem;">Senha</label>
          <input id="password" type="password" placeholder="Senha" required style="width: 100%; padding: 0.7rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.28); color: var(--text);" />

          <button type="submit" style="margin-top: 1rem; width: 100%;">Entrar</button>
        </form>
        <p id="login-error" class="text-red-400 hidden mt-2"></p>
        <button id="logout-btn" class="hidden mt-4 px-4 py-2 bg-red-600 rounded" onclick="logout()">Sair</button>
      </div>

      <!-- Dashboard -->
      <div id="dashboard-section" class="hidden">
        <p class="lead mb-4">Painel Admin - Gerenciar Posts</p>
        <div class="tabs mb-4">
          <button class="tab-btn active" data-tab="posts">Posts</button>
          <button class="tab-btn" data-tab="news">Notícias</button>
        </div>
        
        <!-- Posts Tab -->
        <div id="posts-tab" class="tab-content">
          <div class="flex gap-2 mb-4">
            <input id="search-posts" placeholder="Buscar por título..." class="flex-1 p-2 border rounded">
            <select id="filter-categoria" class="p-2 border rounded">
              <option value="">Todas categorias</option>
              <option value="jurídico">Jurídico</option>
              <option value="parlamentar">Parlamentar</option>
            </select>
            <select id="filter-status" class="p-2 border rounded">
              <option value="">Todos status</option>
              <option value="draft">Rascunho</option>
              <option value="published">Publicado</option>
              <option value="archived">Arquivado</option>
            </select>
            <button id="refresh-posts" class="px-4 py-2 bg-blue-600 rounded">Atualizar</button>
            <button id="create-post-btn" class="px-4 py-2 bg-green-600 rounded">Novo Post</button>
          </div>
          <div id="posts-table" class="overflow-auto">
            <!-- Table populated by JS -->
          </div>
        </div>

        <!-- News Tab stub -->
        <div id="news-tab" class="tab-content hidden">
          <p>Notícias CRUD em breve. Foco inicial em Posts.</p>
        </div>
      </div>

    </main>

    <!-- True Full-Screen Modal (outside main/container for proper overlay) -->
    <div id="post-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm hidden z-[9999] flex items-center justify-center p-6 overflow-y-auto">
      <div class="bg-gray-800/95 p-8 rounded-2xl w-full max-w-4xl max-h-[90vh] shadow-2xl border border-gray-700">
        <div class="flex justify-between items-center mb-6">
          <h3 id="modal-title" class="text-2xl font-bold">Novo Post</h3>
          <button id="close-modal-btn" class="text-gray-400 hover:text-white text-2xl">&times;</button>
        </div>
        <form id="post-form">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div>
              <label class="block mb-3 font-medium">Título</label>
              <input id="post-title" type="text" class="w-full p-4 border border-gray-600 rounded-xl bg-gray-900/50 focus:ring-2 focus:ring-blue-500 focus:border-transparent" required>
            </div>
            <div>
              <label class="block mb-3 font-medium">Categoria</label>
              <select id="post-categoria" class="w-full p-4 border border-gray-600 rounded-xl bg-gray-900/50 focus:ring-2 focus:ring-blue-500 focus:border-transparent" required>
                <option value="jurídico">Jurídico</option>
                <option value="parlamentar">Parlamentar</option>
              </select>
            </div>
          </div>
          
          <div class="mb-6">
            <label class="block mb-3 font-medium">Resumo</label>
            <textarea id="post-summary" class="w-full p-4 border border-gray-600 rounded-xl bg-gray-900/50 focus:ring-2 focus:ring-blue-500 focus:border-transparent" rows="3" required></textarea>
          </div>

          <div class="mb-8">
            <label class="block mb-3 font-medium">Conteúdo (Texto simples → auto convertido para RichText)</label>
            <textarea id="post-content" class="w-full h-64 p-4 border border-gray-600 rounded-xl bg-gray-900/50 focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-vertical" required placeholder="Digite o conteúdo do post aqui..."></textarea>
          </div>

          <div class="flex gap-4 justify-end">
            <button type="button" id="cancel-btn" class="px-8 py-3 bg-gray-600/50 hover:bg-gray-600 text-white font-medium rounded-xl transition-all duration-200">Cancelar</button>
            <button type="submit" class="px-8 py-3 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all duration-200">Salvar Post</button>
          </div>
        </form>
      </div>
    </div>

    <style>
      .tabs { display: flex; border-bottom: 1px solid rgba(255,255,255,0.2); }
      .tab-btn { padding: 0.75rem 1.5rem; background: none; border: none; color: var(--text); cursor: pointer; }
      .tab-btn.active { border-bottom: 2px solid #3b82f6; color: #3b82f6; }
      .tab-content { padding-top: 1rem; }
      table { width: 100%; border-collapse: collapse; }
      th, td { padding: 0.75rem; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.1); }
      .actions button { padding: 0.25rem 0.5rem; margin-right: 0.25rem; border: none; border-radius: 4px; cursor: pointer; font-size: 0.875rem; }
      .status-draft { background: #f59e0b; color: white; padding: 0.25rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; }
      .status-published { background: #10b981; color: white; padding: 0.25rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; }
      .status-archived { background: #6b7280; color: white; padding: 0.25rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; }
      .hidden { display: none !important; }
      .text-red-400 { color: #f87171; }
      input, select, textarea { background: rgba(0,0,0,0.3); border-color: rgba(255,255,255,0.2); color: var(--text); }
    </style>

    <script>
      import * as api from '../lib/api';

      // Variáveis de estado do painel
      let currentPosts: any[] = [];
      let editingId: string | null = null;

      // --- Elementos da UI ---
      const loginForm = document.getElementById('login-form') as HTMLFormElement;
      const loginSection = document.getElementById('login-section');
      const dashboardSection = document.getElementById('dashboard-section');
      const logoutBtn = document.getElementById('logout-btn');
      const loginError = document.getElementById('login-error');
      const postForm = document.getElementById('post-form') as HTMLFormElement;
      const postModal = document.getElementById('post-modal');

      // --- Inicialização e Autenticação ---

      async function checkAuth() {
        const res = await api.fetchMe();
        if (res && res.user && (res.user.roles.includes('admin') || res.user.roles.includes('editor'))) {
          loginSection?.classList.add('hidden');
          dashboardSection?.classList.remove('hidden');
          logoutBtn?.classList.remove('hidden');
          await loadPosts();
        } else {
          // Se não estiver logado, garante que o formulário apareça
          loginSection?.classList.remove('hidden');
          dashboardSection?.classList.add('hidden');
        }
      }

      loginForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = (document.getElementById('email') as HTMLInputElement).value;
        const password = (document.getElementById('password') as HTMLInputElement).value;
        
        const res = await api.login({ email, password });
        
        if (res.error) {
          if (loginError) {
            loginError.textContent = res.error;
            loginError.classList.remove('hidden');
          }
          return;
        }

        if (res.jwt) {
          api.setStoredToken(res.jwt);
          await checkAuth();
        }
      });

      // Funções globais para o navegador (necessárias para onclick no HTML string)
      (window as any).logout = () => {
        api.clearStoredToken();
        location.reload();
      };

      // --- CRUD de Posts ---

      async function loadPosts() {
        const search = (document.getElementById('search-posts') as HTMLInputElement).value.toLowerCase();
        const category = (document.getElementById('filter-categoria') as HTMLSelectElement).value;
        const status = (document.getElementById('filter-status') as HTMLSelectElement).value;
        
        const res = await api.fetchPostsAdmin({ category, status });
        
        if (res && res.docs) {
          currentPosts = res.docs.filter((p: any) => p.title.toLowerCase().includes(search));
          renderTable();
        }
      }

      function renderTable() {
        const container = document.getElementById('posts-table');
        if (!container) return;

        if (currentPosts.length === 0) {
          container.innerHTML = '<p class="p-4 text-center text-gray-400">Nenhum post encontrado.</p>';
          return;
        }

        const tableHTML = `
          <table>
            <thead>
              <tr>
                <th>Título</th>
                <th>Categoria</th>
                <th>Status</th>
                <th>Data</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              ${currentPosts.map(p => `
                <tr>
                  <td class="font-medium">${p.title}</td>
                  <td><span class="capitalize">${p.category || 'N/A'}</span></td>
                  <td><span class="status-${p.status}">${p.status}</span></td>
                  <td>${new Date(p.createdAt).toLocaleDateString('pt-BR')}</td>
                  <td class="actions">
                    <button onclick="window.editPost('${p.id}')" class="bg-blue-600/20 text-blue-400 hover:bg-blue-600/40 px-3 py-1 rounded">Editar</button>
                    <button onclick="window.togglePostStatus('${p.id}', '${p.status}')" class="bg-green-600/20 text-green-400 hover:bg-green-600/40 px-3 py-1 rounded">
                      ${p.status === 'published' ? 'Despublicar' : 'Publicar'}
                    </button>
                    <button onclick="window.deletePost('${p.id}')" class="bg-red-600/20 text-red-400 hover:bg-red-600/40 px-3 py-1 rounded">Excluir</button>
                  </td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        `;
        container.innerHTML = tableHTML;
      }

      // --- Modal e Formulário ---

      (window as any).openModal = (id: string | null = null) => {
        editingId = id;
        const titleEl = document.getElementById('modal-title');
        if (titleEl) titleEl.textContent = id ? 'Editar Post' : 'Novo Post';

        if (id) {
          const post = currentPosts.find(p => p.id === id);
          if (post) {
            (document.getElementById('post-title') as HTMLInputElement).value = post.title;
            (document.getElementById('post-summary') as HTMLTextAreaElement).value = post.summary;
            (document.getElementById('post-categoria') as HTMLSelectElement).value = post.category || 'jurídico';
            // Se for RichText do Payload, convertemos para string para o textarea simples
            (document.getElementById('post-content') as HTMLTextAreaElement).value = 
              typeof post.content === 'object' ? JSON.stringify(post.content, null, 2) : post.content || '';
          }
        } else {
          postForm.reset();
          (document.getElementById('post-categoria') as HTMLSelectElement).value = 'jurídico';
        }
        
        // Show modal + lock scroll
        postModal?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        document.body.style.paddingRight = window.innerWidth - document.documentElement.clientWidth + 'px';
      };

      (window as any).closeModal = () => {
        postModal?.classList.add('hidden');
        document.body.style.overflow = '';
        document.body.style.paddingRight = '';
        editingId = null;
      };

      postForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = {
          title: (document.getElementById('post-title') as HTMLInputElement).value,
          summary: (document.getElementById('post-summary') as HTMLTextAreaElement).value,
          category: (document.getElementById('post-categoria') as HTMLSelectElement).value as 'jurídico' | 'parlamentar',
          content: (document.getElementById('post-content') as HTMLTextAreaElement).value,
          status: editingId ? undefined : 'draft', // Only set on create
        };

        let result;
        if (editingId) {
          result = await api.updatePost(editingId, data);
        } else {
          result = await api.createPost(data);
        }

        if (result) {
          (window as any).closeModal();
          await loadPosts();
        }
      });

      // --- Ações de Linha ---

      (window as any).editPost = (id: string) => (window as any).openModal(id);

      (window as any).deletePost = async (id: string) => {
        if (confirm('Tem certeza que deseja excluir este post permanentemente?')) {
          const success = await api.deletePost(id);
          if (success) await loadPosts();
        }
      };

      (window as any).togglePostStatus = async (id: string, currentStatus: string) => {
        const newStatus = currentStatus === 'published' ? 'draft' : 'published';
        const res = await api.toggleStatus(id, newStatus as any);
        if (res) await loadPosts();
      };

      // --- Eventos de Filtro ---

      document.getElementById('refresh-posts')?.addEventListener('click', loadPosts);
      document.getElementById('create-post-btn')?.addEventListener('click', () => (window as any).openModal(null));
      document.getElementById('cancel-btn')?.addEventListener('click', () => (window as any).closeModal());
      document.getElementById('close-modal-btn')?.addEventListener('click', () => (window as any).closeModal());

      ['search-posts', 'filter-categoria', 'filter-status'].forEach(id => {
        document.getElementById(id)?.addEventListener('input', loadPosts);
      });

      // Troca de Tabs
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
          document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
          
          target.classList.add('active');
          const tabId = target.dataset.tab + '-tab';
          document.getElementById(tabId)?.classList.remove('hidden');
        });
      });

      // Início
      checkAuth();
    </script>
  </div>
</Layout>
