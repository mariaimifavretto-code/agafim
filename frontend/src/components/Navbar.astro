---
const { current = '' } = Astro.props;

const navItems = [
  { href: '/', label: 'Home', icon: 'home' },
  { href: '/sobre', label: 'Sobre', icon: 'info' },
  { href: '/estatuto', label: 'Estatuto', icon: 'paper' },
  { href: '/filiacao', label: 'Filiação', icon: 'users' },
  { href: '/diretoria', label: 'Diretoria', icon: 'award' },
  { href: '/noticias', label: 'Notícias', icon: 'newspaper' },
  { href: '/assuntos-juridicos', label: 'Assuntos Jurídicos', icon: 'gavel' },
  { href: '/assuntos-parlamentares', label: 'Assuntos Parlamentares', icon: 'parliament' },
  { href: '/contato', label: 'Contato', icon: 'mail' },
  { href: '/denuncias', label: 'Denúncias', icon: 'alert' },
  { href: '/area-do-usuario', label: 'Área do Usuário', icon: 'lock' },
];

const icons = {
  home: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2V12H9v8a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2z"/></svg>`,
  info: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>`,
  paper: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="7" y1="9" x2="17" y2="9"/><line x1="7" y1="13" x2="17" y2="13"/><line x1="7" y1="17" x2="17" y2="17"/></svg>`,
  users: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  award: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><path d="M8.21 13.89 7 23l5-3 5 3-1.21-9.11"/><path d="M12 16v-5"/></svg>`,
  newspaper: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v16H4z"/><path d="M8 2v4"/><path d="M16 2v4"/><path d="M4 10h16"/><path d="M8 14h8"/></svg>`,
  gavel: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m14 10 4 4"/><path d="m14 14 4-4"/><path d="m7 7 4.5 4.5"/><path d="m8 16 8 8"/><path d="m12 12 4 4"/></svg>`,
  parliament: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M12 3v18"/><path d="M6 9h12"/><path d="M6 21v-6"/><path d="M18 21v-6"/><path d="M9 9V3"/><path d="M15 9V3"/></svg>`,
  mail: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v16H4z"/><polyline points="22,6 12,13 2,6"/></svg>`,
  alert: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
  lock: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
};

const activeClass = (href) => (current === href ? 'active' : '');
---

<nav class="bg-black/35 border-b border-white/8 sticky top-0 z-20">
  <div class="container flex items-center justify-between gap-4 py-4">
    <input id="nav-toggle" class="nav-toggle hidden" type="checkbox" aria-label="Toggle menu" />
    <label class="mobile-toggle hidden bg-none border-none p-1 cursor-pointer text-text" for="nav-toggle" aria-label="Toggle menu">
      <span class="block w-6 h-0.5 m-1 bg-current rounded-sm"></span>
      <span class="block w-6 h-0.5 m-1 bg-current rounded-sm"></span>
      <span class="block w-6 h-0.5 m-1 bg-current rounded-sm"></span>
    </label>

    <ul class="nav-links flex gap-2 flex-nowrap list-none p-0 m-0">
      {navItems.map((item) => (
        <li class={activeClass(item.href)}>
          <a href={item.href} class="nav-link">
            <span class="nav-icon" set:html={icons[item.icon]} />
            <span class="nav-label">{item.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

